---
import MongoDbIcon from "../layout/icons/databases/MongoDbIcon.astro";
import MySqlIcon from "../layout/icons/databases/MySqlIcon.astro";
import SqlServerIcon from "../layout/icons/databases/SqlServerIcon.astro";
import DockerIcon from "../layout/icons/devtools/DockerIcon.astro";
import PostmanIcon from "../layout/icons/devtools/PostmanIcon.astro";
import SpringbootIcon from "../layout/icons/devtools/SpringbootIcon.astro";
import AngularIcon from "../layout/icons/frameworks/AngularIcon.astro";
import NetCoreIcon from "../layout/icons/frameworks/NetCoreIcon.astro";
import NextJsIcon from "../layout/icons/frameworks/NextJsIcon.astro";
import JavaIcon from "../layout/icons/languages/JavaIcon.astro";
import TailwindIcon from "../layout/icons/libraries/TailwindIcon.astro";
import Typography from "../layout/Typography.astro";

import { t, type Lang } from '../i18n';

const { lang = 'en' } = Astro.props;

const sectionContent = {
    title: t(lang, 'whatido_title'),
    subcontents: [
        t(lang, 'whatido_1'),
        t(lang, 'whatido_2'),
        t(lang, 'whatido_3')
    ]
};

// Array of technology icons
const techIcons = [
  AngularIcon,
  NextJsIcon,
  TailwindIcon,
  JavaIcon,
  SpringbootIcon,
  MongoDbIcon,
  NetCoreIcon,
  MySqlIcon,
  SqlServerIcon,
  DockerIcon,
  PostmanIcon
];

---

<div class="flex flex-col items-center md:items-start border-[1px] border-gray-200 dark:border-gray-700 rounded-lg p-6 bg-white/5 dark:bg-gray-800">

    <div class="flex w-full items-center justify-center mb-4">
        <Typography as="h2" class="mb-6" id="whatido_title">{sectionContent.title}</Typography>
    </div>

    <!-- Infinite Wavy Slide of Tech Icons -->

    <section class="slider-gallery overflow-hidden max-w-full py-4">
        <div class="flex animate-scroll" style="width: calc(5rem * 11);">
        {techIcons.map((IconComponent) => (
            <div class="slide size-16  flex-shrink-0 relative mx-2">
            <IconComponent class="object-cover w-full h-full rounded-lg shadow-md"/>
            </div>
        ))}
        {techIcons.map((IconComponent) => (
            <div class="slide size-16 flex-shrink-0 relative mx-2">
            <IconComponent class="object-cover w-full h-full rounded-lg shadow-md" />
            </div>
        ))}
        </div>
    </section>
    <ul class="mt-2 space-y-1 text-gray-200 gap-y-8">
        {sectionContent.subcontents.map((item, index) => (
            <li class="flex items-start mr-2">
                <div class="flex my-6">
                    <Typography as="span" class="mb-2" data-whatido-item>{item}</Typography>
                </div>
            </li>
        ))}
    </ul>
</div>