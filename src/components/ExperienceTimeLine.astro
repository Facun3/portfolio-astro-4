
---

import ExperienceItem from "./ExperienceItem.astro"
import { t, type Lang } from '../i18n';

const { lang = 'en' } = Astro.props;

const EXPERIENCE = [
    {
        date: "Feb 2024 – Present",
        title: t(lang, 'ssr_fullstack'),
        company: t(lang, 'company_prosocial'),
        desc: [
            t(lang, 'exp_prosocial_1'),
            t(lang, 'exp_prosocial_2')
        ],
        techStack: ["Angular", "Java", "MongoDB", "AWS", "Auth0", "Salesforce"]
    },
    {
        date: "Oct 2023 – Feb 2024",
        title: t(lang, 'software_developer'),
        company: t(lang, 'company_beereal'),
        desc: [
            t(lang, 'exp_beereal_1'),
            t(lang, 'exp_beereal_2')
        ],
        techStack: ["Next.js", "Tailwind CSS", "Strapi"]
    },
    {
        date: "Aug 2022 – Oct 2023",
        title: t(lang, 'fullstack_developer'),
        company: t(lang, 'company_osprera'),
        desc: [
            t(lang, 'exp_osprera_1'),
            t(lang, 'exp_osprera_2')
        ],
        techStack: ["Angular", ".NET Core", "SQL Server", "MS Test"]
    },
    {
        date: "Oct 2021 – Aug 2022",
        title: t(lang, 'fullstack_developer'),
        company: t(lang, 'company_hipodromo'),
        desc: [
            t(lang, 'exp_hipodromo_1'),
            t(lang, 'exp_hipodromo_2')
        ],
        techStack: ["Angular", "Material Design", ".NET Core", "Entity Framework"]
    }
];

---

<ol class="relative border-s border-gray-200 dark:border-gray-700">
    {
        EXPERIENCE.map(experience => (
            <li class="mb-10">
                <ExperienceItem {...experience}/>
            </li>            
        ))
    }                  
</ol>

