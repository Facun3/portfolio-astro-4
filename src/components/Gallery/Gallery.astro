---
const { images = [] } = Astro.props;
---

<div class="gallery-wrapper" aria-label="Photo gallery">
  <div class="gallery-track">
    {images.map((image) => (
      <div class="gallery-item">
        <img src={image.src} alt={image.alt} class="gallery-img" loading="lazy" />
        <div class="gallery-overlay">
          <span class="gallery-caption">{image.caption}</span>
        </div>
      </div>
    ))}
    {/* Duplicate for seamless infinite loop */}
    {images.map((image) => (
      <div class="gallery-item" aria-hidden="true">
        <img src={image.src} alt="" class="gallery-img" loading="lazy" />
        <div class="gallery-overlay">
          <span class="gallery-caption">{image.caption}</span>
        </div>
      </div>
    ))}
  </div>
</div>

<style>
.gallery-wrapper {
  overflow: hidden;
  width: 100%;
  padding: 2rem 0;
  mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
  -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
}

.gallery-wrapper:hover .gallery-track {
  animation-play-state: paused;
}

.gallery-track {
  display: flex;
  gap: 1rem;
  width: max-content;
  animation: gallery-scroll 35s linear infinite;
}

@keyframes gallery-scroll {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}

.gallery-item {
  position: relative;
  flex-shrink: 0;
  width: 300px;
  height: 220px;
  border-radius: 12px;
  overflow: hidden;
  cursor: pointer;
  transition: transform 0.4s ease, z-index 0s;
  z-index: 0;
}

.gallery-item:hover {
  transform: scale(1.12);
  z-index: 10;
}

.gallery-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 12px;
  transition: filter 0.4s ease;
  display: block;
}

.gallery-item:hover .gallery-img {
  filter: brightness(0.8);
}

.gallery-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, transparent 55%);
  border-radius: 12px;
  display: flex;
  align-items: flex-end;
  padding: 0.75rem;
  opacity: 0;
  transition: opacity 0.35s ease;
}

.gallery-item:hover .gallery-overlay {
  opacity: 1;
}

.gallery-caption {
  color: white;
  font-size: 0.78rem;
  font-weight: 500;
  line-height: 1.3;
}

@media (max-width: 640px) {
  .gallery-item {
    width: 220px;
    height: 160px;
  }
}
</style>
