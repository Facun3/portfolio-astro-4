---
import SocialBadge from "./SocialBadge.astro";
import LinkedinIcon from "../../layout/icons/LinkedinIcon.astro";
import Typography from "../../layout/Typography.astro";
import MailIcon from "../../layout/icons/MailIcon.astro";
import GithubIcon from "../../layout/icons/devtools/GithubIcon.astro";
import { t, type Lang } from '../../i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
---

<div class="flex flex-col md:flex-row w-full items-center md:items-start md:justify-center gap-4 border-[1px] border-gray-200 dark:border-gray-700 rounded-lg p-6 bg-white/5 dark:bg-gray-800">
  <div class="flex items-center md:justify-start md:mb-6 md:w-[400px] px-4">
    <img
      src="/profile.webp"
      class="size-[160px] md:size-[250px] rounded-full"
      alt="profile pic"
    />
  </div>
  <div class="flex flex-col items-center md:items-start md:max-w-100">
    <Typography as="h1" className="mt-4" id="hero_name">{t(lang, 'hero_name')}</Typography>
    <Typography as="h2" className="mt-4" id="hero_job_title">{t(lang, 'hero_job_title')}</Typography>
    <Typography as="span" className="mt-2" id="hero_location">{t(lang, 'hero_location')}</Typography>
    <div class="flex w-full md:h-20 items-center">
      <Typography as="span" className="mt-6 opacity-90 italic" id="hero_subtitle">{t(lang, 'hero_subtitle')}</Typography>
    </div>
    <nav class="flex mt-4 gap-x-4">
      <SocialBadge href="https://www.linkedin.com/in/facundo-choque/">
        <LinkedinIcon class="size-5 text-black dark:text-white"/>
        <div class="hidden md:inline"><Typography as="span" id="social_linkedin">{t(lang, 'social_linkedin')}</Typography></div>
      </SocialBadge>
      <SocialBadge href="https://github.com/Facun3">
        <GithubIcon class="size-5 text-black dark:text-white" />
        <div class="hidden md:inline"><Typography as="span" id="social_github">{t(lang, 'social_github')}</Typography></div>
      </SocialBadge>
  
      <SocialBadge href="mailto:dev.facundo.choque@gmail.com?subject=Hello%20Facundo%20">
            <MailIcon class="size-5 text-black dark:text-white"/>
            <div class="hidden md:inline"><Typography as="span" id="social_email">{t(lang, 'social_email')}</Typography></div>  
        </SocialBadge>
    </nav>
  </div>
</div>

